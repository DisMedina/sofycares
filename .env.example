# EmailJS (client-side). All three are PUBLIC / safe to expose in the browser.
# Do NOT add a private key. Get values from https://dashboard.emailjs.com/
# Copy this file to .env and fill in your real values (`.env` is gitignored).
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
