# EmailJS (client-side). All three are PUBLIC / safe to expose in the browser.
# These use the EMAILJS_ prefix, which vite.config.ts exposes to client code.
# SECURITY: never add EMAILJS_PRIVATE_KEY (or any secret with this prefix) —
# anything starting with EMAILJS_ is inlined into the browser bundle.
# Copy this file to .env and fill in your real values (`.env` is gitignored).
# Get values from https://dashboard.emailjs.com/
EMAILJS_SERVICE_ID=your_service_id_here
EMAILJS_TEMPLATE_ID=your_template_id_here
EMAILJS_PUBLIC_KEY=your_public_key_here
